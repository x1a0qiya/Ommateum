# Auto detect text files and ensure LF line endings
* text=auto

# Python source files — always LF
*.py        text eol=lf
*.pyw       text eol=lf
*.pxd       text eol=lf
*.pxi       text eol=lf

# Shell scripts — always LF (必需，否则 Linux 下会报错)
*.sh        text eol=lf
*.bash      text eol=lf

# Config / YAML / Markdown — always LF
*.yml       text eol=lf
*.yaml      text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.cfg       text eol=lf
*.ini       text eol=lf

# Docker
Dockerfile  text eol=lf
*.dockerignore text eol=lf

# Git
.gitignore  text eol=lf
.gitattributes text eol=lf
.gitlab-ci.yml text eol=lf

# HTML / CSS / JS — always LF
*.html      text eol=lf
*.css       text eol=lf
*.js        text eol=lf

# Batch files — always CRLF (Windows CMD 需要)
*.bat       text eol=crlf
*.cmd       text eol=crlf

# PowerShell — LF (pwsh 兼容)
*.ps1       text eol=lf

# Binary files — never touch
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.svg       binary
*.woff      binary
*.woff2     binary
*.eot       binary
*.ttf       binary
*.otf       binary
*.pt        binary
*.pth       binary
*.onnx      binary
*.pb        binary
*.so        binary
*.dll       binary
*.exe       binary
*.zip       binary
*.tar       binary
*.gz        binary
