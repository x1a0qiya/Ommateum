@startuml rag-pipeline

title RAG 检索数据流

rectangle "图片上传" as upload

rectangle "embedding.py" as emb
note right of emb
  CLIP ViT-B-32 (512d)  优先
  ResNet50     (2048d) 兜底
  颜色直方图    (4096d) 最终
end note

database "ChromaDB\ndata/chromadb/" as chroma

rectangle "rag_bridge\nindex_defect()" as idx
rectangle "rag_bridge\nretrieve_similar()" as retrieve

rectangle "active_learning.py" as al
note right of al
  新颖检测
  类别平衡
  难例挖掘
end note

upload -down-> emb
emb -down-> idx
idx -down-> chroma
chroma -down-> retrieve
retrieve -down-> al

@enduml
