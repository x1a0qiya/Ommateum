@startuml data-model-relation

title 数据模型关系总图

component "Image\n图片记录" as image
component "Predict Task\n检测任务" as predict
component "Result\n检测结果" as result
database "ChromaDB\ndefect_samples" as chroma
component "Train Task\n训练任务" as train
component "Weight\n权重记录" as weight
component "Model\n模型描述" as model

image -right-> predict : 引用
predict -right-> result : 产出
image -down-> chroma : RAG 入库
result -down-> chroma : RAG 入库
chroma -down-> train : 检索相似缺陷
image -down-> train : 消费
train -right-> weight : 产出
image -down-> model : 引用
weight -up-> model : 引用

@enduml
