@startuml deployment

title Docker 部署架构

node "Docker\npytorch:2.5.1-cuda12.1" as docker {
  rectangle "端口 8000  —  API / 前端" as p8000
  rectangle "端口 7860  —  Gradio (可选)" as p7860
  rectangle "GPU 直通, IPC host" as gpu
  rectangle "项目目录挂载到 /Ommateum" as mount
}

note right of docker
  单容器部署
  docker-compose up
end note

@enduml
